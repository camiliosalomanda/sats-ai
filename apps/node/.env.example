# Node Identity
NOSTR_PRIVKEY=nsec1...

# Lightning
LN_ADDRESS=you@getalby.com

# Model
MODEL_PATH=./models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
MODEL_NAME=Llama 3.2 3B
MODEL_ID=llama3.2-3b

# Inference server (llama-server HTTP API)
# LLAMA_SERVER_URL=http://127.0.0.1:8080
# LLAMA_SERVER=./llama.cpp/llama-server

# Pricing
SATS_PER_1K=1
MAX_TOKENS=2048

# Relays
RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol

# Resolver mode
RESOLVER_MODE=true
RESOLVER_STAKE_BUDGET_MSATS=100000
MIN_MARKET_VOLUME_MSATS=50000
RESOLVER_CATEGORIES=crypto,macro

# Lightning node (for HTLC management — use ONE)
# LND_REST_URL=https://localhost:8080
# LND_MACAROON=<hex_encoded_macaroon>
# CLN_REST_URL=https://localhost:3010
# CLN_RUNE=<cln_rune_string>

# External data APIs (all free tier)
COINGECKO_API_KEY=
FRED_API_KEY=
NEWS_API_KEY=
